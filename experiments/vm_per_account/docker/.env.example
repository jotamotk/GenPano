# Copy to .env and customize. .env is gitignored.
#
# Each container needs its own VNC password (8+ chars random preferred).
# Generate with: openssl rand -hex 4

VNC_PASSWORD_01=changeme01
VNC_PASSWORD_02=changeme02

# Add more for additional containers:
# VNC_PASSWORD_03=...
# VNC_PASSWORD_DEEPSEEK_01=...
