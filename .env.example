# ── Docker Registry ────────────────────────────────────────────────────────────
ACR_REGISTRY=crpi-vklfeye8td1r1mei.cn-shanghai.personal.cr.aliyuncs.com/lianwei_ai_lab
# 镜像均推送到同一个 genpano 仓库，以 frontend-/backend-/worker- 前缀区分
IMAGE_TAG=latest

# ── Database ───────────────────────────────────────────────────────────────────
POSTGRES_PASSWORD=change_me_strong_password
DATABASE_URL=postgresql+asyncpg://genpano:change_me_strong_password@postgres:5432/genpano

# ── Redis ──────────────────────────────────────────────────────────────────────
REDIS_URL=redis://redis:6379/0

# ── Node.js Backend ────────────────────────────────────────────────────────────
PORT=4000
NODE_ENV=production
FRONTEND_URL=http://your-server-ip
JWT_SECRET=change_me_min_32_chars_random_string
JWT_EXPIRES_IN=7d

# ── Google OAuth (可选) ────────────────────────────────────────────────────────
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_CALLBACK_URL=http://your-server-ip/api/auth/google/callback

# ── Email ──────────────────────────────────────────────────────────────────────
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
EMAIL_FROM=noreply@genpano.com

# ── Proxy ──────────────────────────────────────────────────────────────────────
# 国际 LLM 代理：static | clash | brightdata | oxylabs | smartproxy
PROXY_PROVIDER=clash
# Clash 容器地址（docker-compose 内网访问）
CLASH_PROXY_URL=http://clash:7890
HTTPS_PROXY=http://clash:7890
HTTP_PROXY=http://clash:7890

# ── geo_tracker ────────────────────────────────────────────────────────────────
ZHIPU_API_KEY=
GLM_MODEL=glm-4
CAPSOLVER_API_KEY=
SCREENSHOT_DIR=/data/screenshots

# ── LubanSMS 接码平台（自动注册/登录）──────────────────────────────────────────
LUBANSMS_TOKEN=your_lubansms_api_key
LUBANSMS_PROJECT_DOUBAO=service_id_for_doubao
LUBANSMS_PROJECT_DEEPSEEK=service_id_for_deepseek

# ── LLM Cookies（手动登录后导出的 JSON 格式 cookie 数组）──────────────────────
# 获取方式: 浏览器登录豆包 → F12 → Console → 输入:
#   JSON.stringify(document.cookie.split('; ').map(c => {
#     const [name, ...v] = c.split('=');
#     return {name, value: v.join('='), domain: '.doubao.com', path: '/'};
#   }))
# 或使用 EditThisCookie 等浏览器扩展导出
DOUBAO_COOKIES_JSON=

# DeepSeek Cookies（获取方式同上，domain 改为 '.deepseek.com'）
DEEPSEEK_COOKIES_JSON=
