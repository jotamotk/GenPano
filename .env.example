# GENPANO deployment environment

# Docker registry/images
ACR_REGISTRY=crpi-vklfeye8td1r1mei.cn-shanghai.personal.cr.aliyuncs.com/lianwei_ai_lab
IMAGE_TAG=latest

# Database
POSTGRES_PASSWORD=change_me_strong_password
DATABASE_URL=postgresql+asyncpg://genpano:change_me_strong_password@postgres:5432/genpano

# Redis
REDIS_URL=redis://redis:6379/0

# FastAPI backend
PORT=4000
GENPANO_ENVIRONMENT=production

# Admin auth (FastAPI cookie session for /admin/api/*)
ADMIN_SESSION_SECRET=change_me_min_32_bytes_random_admin_session_secret
ADMIN_BASE_URL=https://your-domain.example/admin
ADMIN_EMAIL_FROM=GenPano Admin <admin@genpano.com>
RESEND_API_KEY=

# Product user auth
USER_JWT_SECRET=change_me_min_32_bytes_random_user_secret
USER_BASE_URL=https://your-domain.example
USER_EMAIL_FROM=GenPano <noreply@genpano.com>
USER_EMAIL_PROVIDER=noop
EMAIL_PROVIDER=noop
ALIYUN_DM_SMTP_HOST=smtpdm.aliyun.com
ALIYUN_DM_SMTP_PORT=465
ALIYUN_DM_SMTP_SSL=true
ALIYUN_DM_SMTP_USER=
ALIYUN_DM_SMTP_PASSWORD=
EMAIL_REPLY_TO=
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_CALLBACK_URL=https://your-domain.example/api/auth/google/callback

# Proxy provider for browser-based engine adapters
PROXY_PROVIDER=clash
CLASH_PROXY_URL=http://host.docker.internal:6789
CLASH_API_URL=http://host.docker.internal:9098
CLASH_PROXY_GROUP=💬 Ai平台
CLASH_API_SECRET=
CLASH_GLOBAL_PROXY_GROUP=GLOBAL
CLASH_FORCE_GLOBAL_PROXY_ROUTE=1

# geo_tracker / analyzer providers
ZHIPU_API_KEY=
GLM_MODEL=glm-4
CAPSOLVER_API_KEY=
SCREENSHOT_DIR=/data/screenshots
BROWSER_BLOCK_HEAVY_RESOURCES=true
COOKIE_KEEP_ALIVE_AUTO_RELOGIN=false

# Volcengine Ark API
ARK_API_KEY=
ARK_BASE_URL=https://ark.cn-beijing.volces.com/api/v3
ARK_MODEL=doubao-seed-2-0-pro-260215

# LubanSMS account registration
LUBANSMS_TOKEN=your_lubansms_api_key
# Per-platform service_id fallback for LubanSMS verification-code API
# ("验证码接收"). Used when the Keyword API ("通用短信接收") returns
# {"code":400,"msg":"未知错误"} or other allocation failures.
# Doubao value: 666056 (operator-provided).
LUBANSMS_DOUBAO_SERVICE_ID=
# Per-platform kill switch for the service-id fallback. When the keyword
# API is healthy and the operator wants registrations to go through it
# exclusively, set this to "1"/"true" to short-circuit the fallback path
# even if ``LUBANSMS_DOUBAO_SERVICE_ID`` is still set. Production
# default is "0" (fallback ENABLED, fail-open) after the keyword API
# was observed failing again at 2026-05-16 15:26:46 UTC with
# {"code":400,"msg":"未知错误"}; flip to "1" to disable the fallback
# once the keyword API is confirmed stable.
LUBANSMS_DOUBAO_DISABLE_SERVICE_ID_FALLBACK=0
# Deprecated: was used by the pre-#121 service-specific provider; kept
# in the env namespace only so older docker-compose files do not break.
# Safe to leave empty / remove.
LUBANSMS_PROJECT_DOUBAO=

# qg.net (青果网络) rotating proxy IP — bypasses Doubao's by-IP
# shadow-ban / 5202 captcha-denial by handing each Doubao query a
# fresh residential / mobile IP. All three values are required to
# activate the path; if any is empty, Doubao falls back to the worker's
# native egress (current behaviour).
#
# - QG_PROXY_EXTRACT_URL: the full extract API URL generated in the qg
#   dashboard, including the apikey and any area / num / format params.
#   Example: https://share.proxy.qg.net/get?key=YOUR_KEY&num=10&...
# - QG_PROXY_AUTH_KEY / QG_PROXY_AUTH_PASSWORD: account-mode credentials
#   for the rotating IPs. Each IP is used with
#   http://AUTH_KEY:AUTH_PASSWORD@IP:PORT
QG_PROXY_EXTRACT_URL=
QG_PROXY_AUTH_KEY=
QG_PROXY_AUTH_PASSWORD=

# Manually exported LLM cookies, JSON array format.
#
# NOTE (Phase 3 cleanup, Refs #1118 / Epic #1110): the env-cookie injection
# variables for doubao and deepseek were removed in favour of the
# vm_session execution mode (ADR-016). Cookies for doubao / deepseek now
# come from AccountPool + the vm_side runner; do not reintroduce
# env-variable injection for those engines. GEMINI_COOKIES_JSON is
# unaffected (non-MVP engine).
GEMINI_COOKIES_JSON=
