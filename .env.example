# ── Docker Registry ────────────────────────────────────────────────────────────
ACR_REGISTRY=registry.cn-singapore.aliyuncs.com/your-namespace
IMAGE_TAG=latest

# ── Database ───────────────────────────────────────────────────────────────────
POSTGRES_PASSWORD=change_me_strong_password
DATABASE_URL=postgresql+asyncpg://genpano:change_me_strong_password@postgres:5432/genpano

# ── Redis ──────────────────────────────────────────────────────────────────────
REDIS_URL=redis://redis:6379/0

# ── Node.js Backend ────────────────────────────────────────────────────────────
PORT=4000
NODE_ENV=production
FRONTEND_URL=http://your-server-ip
JWT_SECRET=change_me_min_32_chars_random_string
JWT_EXPIRES_IN=7d

# ── Google OAuth (可选) ────────────────────────────────────────────────────────
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_CALLBACK_URL=http://your-server-ip/api/auth/google/callback

# ── Email ──────────────────────────────────────────────────────────────────────
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
EMAIL_FROM=noreply@genpano.com

# ── geo_tracker ────────────────────────────────────────────────────────────────
ZHIPU_API_KEY=
GLM_MODEL=glm-4
CAPSOLVER_API_KEY=
SCREENSHOT_DIR=/data/screenshots
