# Server
PORT=4000
NODE_ENV=development
FRONTEND_URL=http://localhost:3000

# JWT (legacy TS era, retained for migration parity)
JWT_SECRET=your-super-secret-jwt-key-change-in-production-min-32-chars
JWT_EXPIRES_IN=7d

# Google OAuth (get from https://console.cloud.google.com)
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret
GOOGLE_CALLBACK_URL=http://localhost:4000/api/auth/google/callback

# Email via Resend HTTP API (recommended, https://resend.com)
# If set, takes priority over SMTP
RESEND_API_KEY=
EMAIL_FROM=GenPano <onboarding@resend.dev>

# SMTP fallback (leave empty to use Ethereal in dev)
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=

# Legacy Next.js DB path (TS era, retained for compat)
DB_PATH=./data/genpano.db

# ----------------------------------------------------------------------------
# Python pivot (CLAUDE.md decision #29) -- Step 7 introduces these env vars
# ----------------------------------------------------------------------------

# SQLAlchemy 2.0 async URL.
# Default: sqlite+aiosqlite:///./dev.db (see app/core/config.py)
# GENPANO_DATABASE_URL takes priority over the legacy DATABASE_URL alias.
GENPANO_DATABASE_URL=
DATABASE_URL=

# Redis broker / result backend for Celery (6-queue topology, decision #29).
# Default: redis://localhost:6379/0 (see app/celery_app.py)
GENPANO_REDIS_URL=
REDIS_URL=

# ----------------------------------------------------------------------------
# Supabase preview branch -- Step 11 verify-session-0prime.sh validation only.
# Step 7 does NOT consume these. Frank creates the preview branch in the
# Supabase web console and pastes connection metadata into .env.preview
# (gitignored) before Step 11 runs the smoke script.
# ----------------------------------------------------------------------------
SUPABASE_PREVIEW_DB_URL=
SUPABASE_JWT_SECRET=
SUPABASE_SERVICE_ROLE_KEY=

# ----------------------------------------------------------------------------
# Admin module (Session A0' + A1', CLAUDE.md decision #29 / #30 / #24)
# ----------------------------------------------------------------------------

# JWT signing key for /admin/api/v1/auth/* tokens.
# REQUIRED for backend boot — backend/app/admin/auth/jwt.py raises
# AdminJwtSecretMissingError if missing or < 32 bytes (decision #24.B / D8).
# Generate with: python -c "import secrets; print(secrets.token_urlsafe(48))"
ADMIN_JWT_SECRET=

# Admin frontend base URL. Used by password-reset / invitation email templates
# to build the click-through link (backend/app/admin/auth/email.py:52, fallback
# http://localhost:5173). Local dev: http://localhost:5173 ; prod: Vercel URL.
# NOTE: env var is ADMIN_BASE_URL (code-correct), not ADMIN_FRONTEND_URL.
ADMIN_BASE_URL=

# Resend HTTP API key for admin password-reset / invitation emails
# (backend/app/admin/auth/email.py:67). Empty = mock mode: _send() returns
# EmailResult(delivered=False) and logs admin_email.skipped (Session A0' Step 11
# G_A0.3.8/9 verified, decision #30.D Bug 4 logger gap → Session A1').
# Session 4a' switches to live (decision iii). Same key reused from line 17.
# RESEND_API_KEY=  (already declared above for legacy/Python shared use)
