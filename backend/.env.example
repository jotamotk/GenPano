# GENPANO FastAPI backend
PORT=4000
GENPANO_ENVIRONMENT=development

# SQLAlchemy async URL. GENPANO_DATABASE_URL takes priority over DATABASE_URL.
# Local default in app/core/config.py: sqlite+aiosqlite:///./dev.db
GENPANO_DATABASE_URL=
DATABASE_URL=

# Celery broker/result backend. GENPANO_REDIS_URL takes priority over REDIS_URL.
# Local default in app/core/config.py: redis://localhost:6379/0
GENPANO_REDIS_URL=
REDIS_URL=

# Admin auth. Must be at least 32 bytes in every non-test runtime.
ADMIN_JWT_SECRET=change_me_min_32_bytes_random_admin_secret
ADMIN_BASE_URL=http://localhost:3000/admin

# Admin transactional email. If RESEND_API_KEY is empty, email sending no-ops in
# local/CI flows while auth records are still created.
RESEND_API_KEY=
ADMIN_EMAIL_FROM=GenPano Admin <admin@genpano.com>

# Supabase preview branch validation only.
SUPABASE_PREVIEW_DB_URL=
SUPABASE_JWT_SECRET=
SUPABASE_SERVICE_ROLE_KEY=
