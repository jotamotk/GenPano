# GENPANO FastAPI backend
PORT=4000
GENPANO_ENVIRONMENT=development

# SQLAlchemy async URL. GENPANO_DATABASE_URL takes priority over DATABASE_URL.
# Local default in app/core/config.py: sqlite+aiosqlite:///./dev.db
GENPANO_DATABASE_URL=
DATABASE_URL=

# Celery broker/result backend. GENPANO_REDIS_URL takes priority over REDIS_URL.
# Local default in app/core/config.py: redis://localhost:6379/0
GENPANO_REDIS_URL=
REDIS_URL=

# Product user auth. Must be at least 32 bytes in every non-test runtime.
USER_JWT_SECRET=change_me_min_32_bytes_random_user_secret
USER_BASE_URL=http://localhost:3000
USER_EMAIL_FROM=GenPano <noreply@genpano.com>
USER_EMAIL_PROVIDER=noop

# Product user transactional email provider:
# - noop: local/CI default, creates tokens but does not send real email
# - resend: send through Resend using RESEND_API_KEY
# - aliyun_dm: send through Aliyun DirectMail SMTP
EMAIL_PROVIDER=noop
ALIYUN_DM_SMTP_HOST=smtpdm.aliyun.com
ALIYUN_DM_SMTP_PORT=465
ALIYUN_DM_SMTP_SSL=true
ALIYUN_DM_SMTP_USER=
ALIYUN_DM_SMTP_PASSWORD=
EMAIL_REPLY_TO=
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_CALLBACK_URL=http://localhost:3000/api/auth/google/callback

# Resend transactional email. If no provider credentials are configured, email
# sending no-ops in local/CI flows while auth records are still created.
RESEND_API_KEY=
# Supabase preview branch validation only.
SUPABASE_PREVIEW_DB_URL=
SUPABASE_JWT_SECRET=
SUPABASE_SERVICE_ROLE_KEY=
